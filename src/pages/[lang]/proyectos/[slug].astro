---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import QuoteRouterModal from "../../../components/hub/QuoteRouterModal";
import { getDictionary, buildPath, type Lang } from "../../../i18n/config";
import { projectsCatalog } from "../../../data/projectsExperience";
import { hubServiceCategories, hubServices } from "../../../data/hub";

export function getStaticPaths() {
  return projectsCatalog.map((project) => ({ params: { lang: "es", slug: project.slug } }));
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const dict = getDictionary(lang);
const project = projectsCatalog.find((item) => item.slug === slug);
const projectContent = project ? dict.projectsPage.content[project.slug] : undefined;
const caseStudy = project ? dict.projectsPage.caseStudies[project.slug] : undefined;
const backPath = buildPath(lang, "projects");
const contactPath = buildPath(lang, "contact");
const servicesPath = buildPath(lang, "services");
const projectTypeByDivision = {
  residential: dict.home.quoteRouter.projectTypes[0],
  commercial: dict.home.quoteRouter.projectTypes[1],
  industrial: dict.home.quoteRouter.projectTypes[2],
} as const;

if (!project || !projectContent || !caseStudy) {
  throw new Error(`Unknown project slug: ${slug}`);
}
---

<BaseLayout
  lang={lang}
  dict={dict}
  title={`${projectContent.title} • ${dict.common.brand}`}
  description={projectContent.goal}
>
  <section class="py-8">
    <a href={backPath} class="text-sm font-semibold text-bw-primary hover:underline">
      {dict.projectsPage.caseStudy.back}
    </a>
    <div class="mt-4 grid gap-8 lg:grid-cols-[1.1fr_0.9fr] items-start">
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold text-bw-navy">{projectContent.title}</h1>
        <span class="mt-3 inline-flex rounded-full border border-bw-lightgray bg-bw-lightblue/50 px-3 py-1 text-xs text-bw-navy">
          {dict.projectsPage.divisions[project.division]}
        </span>
        <p class="mt-4 text-bw-gray max-w-prose">{projectContent.goal}</p>
      </div>
      <div class="rounded-2xl border border-bw-lightgray bg-white p-4">
        <img src={project.image || "/images/project-preview-residential.svg"} alt={projectContent.title} class="h-52 w-full rounded-xl object-cover" />
      </div>
    </div>
  </section>

  <section class="py-8 border-t border-bw-lightgray">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.projectsPage.caseStudy.overview}</h2>
    <p class="mt-3 text-bw-gray max-w-prose">{caseStudy.overview}</p>
  </section>

  <section class="py-8 border-t border-bw-lightgray bg-bw-lightblue/40">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.projectsPage.caseStudy.scope}</h2>
    <ul class="mt-4 list-disc pl-5 text-bw-gray space-y-2">
      {caseStudy.scope.map((item: string) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="py-8 border-t border-bw-lightgray">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.projectsPage.caseStudy.approach}</h2>
    <ul class="mt-4 list-disc pl-5 text-bw-gray space-y-2">
      {caseStudy.approach.map((item: string) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="py-8 border-t border-bw-lightgray bg-bw-lightblue/40">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.projectsPage.caseStudy.challenges}</h2>
    <p class="mt-3 text-bw-gray max-w-prose">{caseStudy.challenges}</p>
  </section>

  <section class="py-8 border-t border-bw-lightgray">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.projectsPage.caseStudy.outcome}</h2>
    <p class="mt-3 text-bw-gray max-w-prose">{caseStudy.outcome}</p>
  </section>

  <section class="py-8 border-t border-bw-lightgray bg-bw-lightblue/40">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.projectsPage.caseStudy.servicesUsed}</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {project.servicesUsed.map((serviceId) => (
        <a
          href={servicesPath}
          class="inline-flex rounded-full border border-bw-lightgray bg-white px-3 py-1.5 text-xs font-semibold text-bw-navy hover:bg-bw-lightblue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-primary/60"
        >
          {dict.home.serviceCategories[serviceId]}
        </a>
      ))}
    </div>
    <a
      href={contactPath}
      data-quote-open="true"
      data-project={projectTypeByDivision[project.division]}
      data-service={project.suggestedServiceId}
      data-campaign="projects"
      data-content={project.slug}
      class="mt-6 inline-flex items-center rounded-md bg-bw-primary px-5 py-2.5 text-sm font-semibold text-white shadow transition hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-primary/60"
    >
      {dict.projectsPage.caseStudy.cta}
    </a>
  </section>

  <QuoteRouterModal
    client:load
    dict={dict}
    serviceCategories={hubServiceCategories}
    services={hubServices}
    contactPath={contactPath}
  />
</BaseLayout>
