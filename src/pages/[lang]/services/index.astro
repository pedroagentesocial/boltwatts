---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ServicesExperience from "../../../components/services/ServicesExperience";
import QuoteRouterModal from "../../../components/hub/QuoteRouterModal";
import { getDictionary, buildPath, type Lang } from "../../../i18n/config";
import { hubServiceCategories, hubServices } from "../../../data/hub";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
const dict = getDictionary(lang);
const contactPath = buildPath(lang, "contact");
---

<BaseLayout
  lang={lang}
  dict={dict}
  title={`${dict.servicesPage.title} • ${dict.common.brand}`}
  description={dict.servicesPage.subtitle}
>
  <ServicesExperience client:load dict={dict} lang={lang} contactPath={contactPath} />
  <QuoteRouterModal
    client:load
    dict={dict}
    serviceCategories={hubServiceCategories}
    services={hubServices}
    contactPath={contactPath}
  />
</BaseLayout>
