---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostHeroExperience from "../../components/hub/PostHeroExperience";
import QuoteRouterModal from "../../components/hub/QuoteRouterModal";
import { getDictionary, isSupportedLang, buildPath, withBasePath, type Lang } from "../../i18n/config";
import { hubServiceCategories, hubServices } from "../../data/hub";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const { lang } = Astro.params as { lang: string };
const activeLang: Lang = isSupportedLang(lang) ? (lang as Lang) : "en";
const dict = getDictionary(activeLang);
const contactPath = buildPath(activeLang, "contact");
const servicesPath = buildPath(activeLang, "services");
const projectsPath = buildPath(activeLang, "projects");
const aboutPath = buildPath(activeLang, "about");
const heroSlides = [
  {
    title: dict.home.title,
    subtitle: dict.home.subtitle,
    primaryLabel: dict.home.heroCtas.primary,
    primaryHref: contactPath,
    secondaryLabel: dict.home.heroCtas.secondary,
    secondaryHref: servicesPath,
    src: withBasePath("/videos/hero2.mp4"),
    fallbackSrc: withBasePath("/videos/hero2.mp4"),
  },
  {
    title: dict.home.divisionRouter.title,
    subtitle: dict.home.divisionRouter.subtitle,
    primaryLabel: dict.common.nav.services,
    primaryHref: servicesPath,
    secondaryLabel: dict.common.nav.projects,
    secondaryHref: projectsPath,
    src: withBasePath("/videos/hero1.mp4"),
    fallbackSrc: withBasePath("/videos/hero1.mp4"),
  },
  {
    title: dict.home.finalCta.title,
    subtitle: dict.home.finalCta.subtitle,
    primaryLabel: dict.common.nav.about,
    primaryHref: aboutPath,
    secondaryLabel: dict.common.nav.contact,
    secondaryHref: contactPath,
    src: withBasePath("/videos/hero3.mp4"),
    fallbackSrc: withBasePath("/videos/hero3.mp4"),
  },
];
const carouselLabels =
  activeLang === "es"
    ? {
        previous: "Video anterior",
        next: "Siguiente video",
        goTo: "Ir al video",
        slide: "Video",
      }
    : {
        previous: "Previous video",
        next: "Next video",
        goTo: "Go to video",
        slide: "Video",
      };
---

<BaseLayout
  lang={activeLang}
  dict={dict}
  title={`${dict.common.brand} • ${dict.home.title}`}
  description={dict.home.subtitle}
>
  <section
    data-hero-carousel
    class="relative left-1/2 right-1/2 w-screen min-h-[360px] -translate-x-1/2 overflow-hidden bg-black sm:min-h-[500px] lg:min-h-[560px] motion-safe:animate-in motion-safe:fade-in motion-safe:slide-in-from-bottom-4"
  >
    <div data-carousel-track class="absolute inset-0 z-20 flex h-full transition-transform duration-700 ease-in-out will-change-transform">
      {heroSlides.map((slide, index) => (
        <div data-carousel-slide class="relative h-full min-w-full">
          <video
            class="absolute inset-0 h-full w-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload={index === 0 ? "auto" : "metadata"}
            poster={withBasePath("/images/logo.png")}
            aria-label={`${carouselLabels.slide} ${index + 1}`}
            data-fallback-src={slide.fallbackSrc}
          >
            <source src={slide.src} />
          </video>
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-black/70 via-black/45 to-black/30"></div>
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent"></div>
          <div class="container-responsive relative z-10">
            <div class="grid min-h-[360px] items-end gap-6 py-6 sm:gap-8 sm:py-12 lg:min-h-[520px] lg:py-16">
              <div
                data-carousel-content
                class={`max-w-xl transition-all duration-700 ease-out sm:max-w-2xl ${
                  index === 0 ? "translate-y-0 opacity-100" : "translate-y-4 opacity-0"
                }`}
              >
                <h1 class="text-[1.72rem] font-bold leading-tight text-white drop-shadow-[0_2px_10px_rgba(0,0,0,0.45)] min-[390px]:text-[1.95rem] sm:text-4xl lg:text-5xl">{slide.title}</h1>
                <p class="mt-3 max-w-prose text-sm text-white drop-shadow-[0_2px_10px_rgba(0,0,0,0.45)] min-[390px]:text-base sm:mt-4 sm:text-lg">{slide.subtitle}</p>
                <div class="mt-5 flex flex-col gap-3 sm:mt-6 sm:flex-row sm:flex-wrap">
                  <a
                    href={slide.primaryHref}
                    data-quote-open={slide.primaryHref === contactPath ? "true" : undefined}
                    class="inline-flex w-full items-center justify-center rounded-full bg-bw-primary px-5 py-2.5 text-sm font-semibold text-white shadow hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-primary/60 sm:w-auto"
                  >
                    {slide.primaryLabel}
                  </a>
                  <a
                    href={slide.secondaryHref}
                    class="inline-flex w-full items-center justify-center rounded-full border border-white/70 bg-black/20 px-5 py-2.5 text-sm font-semibold text-white backdrop-blur-[1px] hover:bg-white/15 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80 sm:w-auto"
                  >
                    {slide.secondaryLabel}
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <button
      type="button"
      data-carousel-prev
      aria-label={carouselLabels.previous}
      class="absolute left-3 top-1/2 z-20 hidden -translate-y-1/2 items-center justify-center rounded-full bg-white/85 text-bw-navy shadow hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80 md:inline-flex md:h-9 md:w-9"
    >
      &#8249;
    </button>
    <button
      type="button"
      data-carousel-next
      aria-label={carouselLabels.next}
      class="absolute right-3 top-1/2 z-20 hidden -translate-y-1/2 items-center justify-center rounded-full bg-white/85 text-bw-navy shadow hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80 md:inline-flex md:h-9 md:w-9"
    >
      &#8250;
    </button>
    <div class="absolute bottom-2 left-1/2 z-20 flex -translate-x-1/2 items-center gap-2 pb-1 sm:bottom-4 sm:pb-0">
      {heroSlides.map((_, index) => (
        <button
          type="button"
          data-carousel-dot
          data-carousel-index={index}
          aria-label={`${carouselLabels.goTo} ${index + 1}`}
          class={`h-3 w-3 rounded-full border border-white/80 transition-all duration-300 ${
            index === 0 ? "bg-white scale-110" : "bg-white/40"
          }`}
        />
      ))}
    </div>
  </section>

  <PostHeroExperience client:load dict={dict} lang={activeLang} contactPath={contactPath} projectsPath={projectsPath} />

  <QuoteRouterModal
    client:load
    dict={dict}
    serviceCategories={hubServiceCategories}
    services={hubServices}
    contactPath={contactPath}
  />
  <script is:inline>
    document.querySelectorAll('[data-hero-carousel]').forEach((carousel) => {
      const track = carousel.querySelector('[data-carousel-track]');
      const dots = Array.from(carousel.querySelectorAll('[data-carousel-dot]'));
      const videos = Array.from(carousel.querySelectorAll('video'));
      const slides = Array.from(carousel.querySelectorAll('[data-carousel-slide]'));
      const prevButton = carousel.querySelector('[data-carousel-prev]');
      const nextButton = carousel.querySelector('[data-carousel-next]');
      if (!(track instanceof HTMLElement) || dots.length === 0) return;

      videos.forEach((video) => {
        if (!(video instanceof HTMLVideoElement)) return;
        video.addEventListener('error', () => {
          const source = video.querySelector('source');
          const fallbackSrc = video.dataset.fallbackSrc;
          if (!(source instanceof HTMLSourceElement) || !fallbackSrc) return;
          if (source.getAttribute('src') === fallbackSrc || video.dataset.fallbackApplied === 'true') return;
          source.setAttribute('src', fallbackSrc);
          video.dataset.fallbackApplied = 'true';
          video.load();
          video.play().catch(() => {});
        });
      });

      const totalSlides = dots.length;
      let currentIndex = 0;
      let autoSlideTimer;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const updateSlide = (targetIndex) => {
        currentIndex = (targetIndex + totalSlides) % totalSlides;
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        slides.forEach((slide, index) => {
          if (!(slide instanceof HTMLElement)) return;
          const content = slide.querySelector('[data-carousel-content]');
          const isActive = index === currentIndex;
          if (!(content instanceof HTMLElement)) return;
          content.classList.toggle('opacity-100', isActive);
          content.classList.toggle('translate-y-0', isActive);
          content.classList.toggle('opacity-0', !isActive);
          content.classList.toggle('translate-y-4', !isActive);
        });
        dots.forEach((dot, index) => {
          const isActive = index === currentIndex;
          dot.classList.toggle('bg-white', isActive);
          dot.classList.toggle('scale-110', isActive);
          dot.classList.toggle('bg-white/40', !isActive);
          dot.setAttribute('aria-current', isActive ? 'true' : 'false');
        });
      };

      const startAutoSlide = () => {
        if (prefersReducedMotion) return;
        clearInterval(autoSlideTimer);
        autoSlideTimer = window.setInterval(() => updateSlide(currentIndex + 1), 5000);
      };

      const pauseAutoSlide = () => {
        clearInterval(autoSlideTimer);
      };

      prevButton?.addEventListener('click', () => {
        updateSlide(currentIndex - 1);
        startAutoSlide();
      });

      nextButton?.addEventListener('click', () => {
        updateSlide(currentIndex + 1);
        startAutoSlide();
      });

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const targetIndex = Number(dot.getAttribute('data-carousel-index') || '0');
          updateSlide(targetIndex);
          startAutoSlide();
        });
      });

      carousel.addEventListener('mouseenter', pauseAutoSlide);
      carousel.addEventListener('mouseleave', startAutoSlide);
      carousel.addEventListener('focusin', pauseAutoSlide);
      carousel.addEventListener('focusout', startAutoSlide);

      updateSlide(0);
      startAutoSlide();
    });
  </script>
</BaseLayout>
