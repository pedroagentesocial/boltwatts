---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getDictionary, buildPath, type Lang } from "../../../i18n/config";
import { siteConfig } from "../../../config/site";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
const dict = getDictionary(lang);
const homePath = buildPath(lang, "home");
---

<BaseLayout
  lang={lang}
  dict={dict}
  title={`${dict.maintenancePage.title} • ${dict.common.brand}`}
  description={dict.maintenancePage.subtitle}
>
  <section data-animate class="py-8 data-[state=visible]:animate-in data-[state=visible]:fade-in data-[state=visible]:slide-in-from-bottom-4">
    <h1 class="text-3xl sm:text-4xl font-bold text-bw-navy">{dict.maintenancePage.title}</h1>
    <p class="mt-3 text-bw-gray max-w-prose">{dict.maintenancePage.subtitle}</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a
        href={`${homePath}#contact`}
        class="inline-flex items-center rounded-md bg-bw-primary px-5 py-2.5 text-white text-sm font-semibold shadow hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-primary/60"
      >
        {dict.maintenancePage.ctaPrimary}
      </a>
      <a
        href={siteConfig.phoneHref}
        class="inline-flex items-center rounded-md bg-bw-secondary px-5 py-2.5 text-white text-sm font-semibold shadow hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-secondary/60"
      >
        {dict.maintenancePage.ctaSecondary}
      </a>
    </div>
  </section>

  <section data-animate class="py-10 border-t border-bw-lightgray data-[state=visible]:animate-in data-[state=visible]:fade-in data-[state=visible]:slide-in-from-bottom-4">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.maintenancePage.plansTitle}</h2>
    <div class="mt-6 grid gap-4 lg:grid-cols-3">
      {dict.maintenancePage.plans.map((plan) => (
        <div class="rounded-2xl border border-bw-lightgray bg-white p-6 shadow-sm">
          <p class="text-xs uppercase tracking-[0.2em] text-bw-gray">{plan.tag}</p>
          <h3 class="mt-2 text-xl font-semibold text-bw-navy">{plan.name}</h3>
          <ul class="mt-4 list-disc pl-5 text-sm text-bw-gray space-y-2">
            {plan.benefits.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <div class="mt-5 flex gap-3">
            <a
              href={`${homePath}#contact`}
              class="inline-flex items-center rounded-md bg-bw-primary px-4 py-2 text-xs font-semibold text-white shadow hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-primary/60"
            >
              {dict.maintenancePage.ctaPrimary}
            </a>
            <a
              href={siteConfig.phoneHref}
              class="inline-flex items-center rounded-md bg-bw-secondary px-4 py-2 text-xs font-semibold text-white shadow hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-secondary/60"
            >
              {dict.maintenancePage.ctaSecondary}
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section data-animate class="py-10 border-t border-bw-lightgray data-[state=visible]:animate-in data-[state=visible]:fade-in data-[state=visible]:slide-in-from-bottom-4">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.maintenancePage.compareTitle}</h2>
    <div class="mt-6 overflow-auto">
      <table class="w-full min-w-[520px] border border-bw-lightgray text-sm">
        <thead class="bg-bw-lightblue/40 text-bw-navy">
          <tr>
            {dict.maintenancePage.compareHeaders.map((header) => (
              <th class="px-4 py-3 text-left font-semibold">{header}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {dict.maintenancePage.compareRows.map((row) => (
            <tr class="border-t border-bw-lightgray">
              <td class="px-4 py-3 text-bw-navy font-medium">{row[0]}</td>
              {row.slice(1).map((value) => (
                <td class="px-4 py-3 text-center text-bw-gray">
                  {value ? "✓" : "—"}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section data-animate class="py-10 border-t border-bw-lightgray data-[state=visible]:animate-in data-[state=visible]:fade-in data-[state=visible]:slide-in-from-bottom-4">
    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-2xl border border-bw-lightgray bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-bw-navy">{dict.maintenancePage.checklistTitle}</h2>
        <ul class="mt-4 list-disc pl-5 text-sm text-bw-gray space-y-2">
          {dict.maintenancePage.checklist.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
      <div class="rounded-2xl border border-bw-lightgray bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-bw-navy">{dict.maintenancePage.faqTitle}</h2>
        <div class="mt-4 space-y-4">
          {dict.maintenancePage.faqs.map((item) => (
            <div class="rounded-lg border border-bw-lightgray p-4">
              <p class="text-sm font-semibold text-bw-navy">{item.q}</p>
              <p class="mt-2 text-sm text-bw-gray">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
