---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getDictionary, buildPath, type Lang } from "../../../i18n/config";
import { siteConfig } from "../../../config/site";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const { lang } = Astro.params as { lang: Lang };
const dict = getDictionary(lang);
const homePath = buildPath(lang, "home");
---

<BaseLayout
  lang={lang}
  dict={dict}
  title={`${dict.reviewsPage.title} • ${dict.common.brand}`}
  description={dict.reviewsPage.subtitle}
>
  <section class="py-8" aria-labelledby="reviews-title">
    <h1 id="reviews-title" class="text-3xl sm:text-4xl font-bold text-bw-navy">{dict.reviewsPage.title}</h1>
    <p class="mt-3 text-bw-gray max-w-prose">{dict.reviewsPage.subtitle}</p>
  </section>

  <section class="py-8 border-t border-bw-lightgray" aria-labelledby="highlights-title">
    <h2 id="highlights-title" class="text-2xl font-semibold text-bw-navy">{dict.reviewsPage.highlightsTitle}</h2>
    <ul class="mt-4 list-disc pl-5 text-sm text-bw-gray space-y-2">
      {dict.reviewsPage.highlights.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="py-8 border-t border-bw-lightgray" aria-labelledby="cards-title">
    <h2 id="cards-title" class="text-2xl font-semibold text-bw-navy">{dict.reviewsPage.cardsTitle}</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {dict.reviewsPage.cards.map((card) => (
        <article class="rounded-2xl border border-bw-lightgray bg-white p-6 shadow-sm">
          <p class="text-sm text-bw-gray">"{card.text}"</p>
          <p class="mt-4 text-sm font-semibold text-bw-navy">{card.name}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-8 border-t border-bw-lightgray" aria-labelledby="cta-title">
    <div class="rounded-2xl border border-bw-lightgray bg-bw-lightblue/40 p-6 sm:p-8">
      <h2 id="cta-title" class="text-2xl font-semibold text-bw-navy">{dict.reviewsPage.ctaTitle}</h2>
      <p class="mt-2 text-bw-gray max-w-prose">{dict.reviewsPage.ctaText}</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={`${homePath}#contact`}
          class="inline-flex items-center rounded-md bg-bw-primary px-5 py-2.5 text-white text-sm font-semibold shadow hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-primary/60"
        >
          {dict.reviewsPage.ctaPrimary}
        </a>
        <a
          href={siteConfig.phoneHref}
          class="inline-flex items-center rounded-md bg-bw-secondary px-5 py-2.5 text-white text-sm font-semibold shadow hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-secondary/60"
        >
          {dict.reviewsPage.ctaSecondary}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
