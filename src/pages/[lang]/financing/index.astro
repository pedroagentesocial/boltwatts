---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getDictionary, buildPath, type Lang } from "../../../i18n/config";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
const dict = getDictionary(lang);
const homePath = buildPath(lang, "home");
const servicesPath = buildPath(lang, "services");
---

<BaseLayout
  lang={lang}
  dict={dict}
  title={`${dict.financingPage.title} • ${dict.common.brand}`}
  description={dict.financingPage.subtitle}
>
  <section class="py-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-bw-navy">{dict.financingPage.title}</h1>
    <p class="mt-3 text-bw-gray max-w-prose">{dict.financingPage.subtitle}</p>
    <div class="mt-4 flex flex-wrap gap-4 text-sm">
      <a href={servicesPath} class="font-semibold text-bw-primary hover:underline">{dict.common.nav.services}</a>
      <a href={homePath} class="font-semibold text-bw-primary hover:underline">{dict.common.nav.home}</a>
    </div>
  </section>

  <section class="rounded-2xl border border-bw-lightgray bg-white p-8 shadow-sm">
    <h2 class="text-2xl font-semibold text-bw-navy">{dict.financingPage.introTitle}</h2>
    <p class="mt-3 text-bw-gray max-w-prose">{dict.financingPage.introText}</p>
  </section>

  <section class="mt-10 grid gap-6 lg:grid-cols-2">
    <div class="rounded-2xl border border-bw-lightgray bg-white p-8 shadow-sm">
      <h2 class="text-xl font-semibold text-bw-navy">{dict.financingPage.stepsTitle}</h2>
      <ol class="mt-4 list-decimal pl-5 text-bw-gray space-y-2">
        {dict.financingPage.steps.map((step) => (
          <li>{step}</li>
        ))}
      </ol>
      <p class="mt-4 text-xs text-bw-gray">{dict.financingPage.compliance}</p>
    </div>
    <div class="rounded-2xl border border-bw-lightgray bg-bw-lightblue/40 p-8">
      <h2 class="text-xl font-semibold text-bw-navy">{dict.financingPage.promotionsTitle}</h2>
      <p class="mt-2 text-sm text-bw-gray">{dict.financingPage.promotionsSubtitle}</p>
      <div class="mt-4 grid gap-3">
        {dict.financingPage.promotions.map((promo) => (
          <div class="rounded-lg border border-bw-lightgray bg-white p-4 text-sm text-bw-gray">
            {promo}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-bw-lightgray bg-white p-8 shadow-sm">
    <h2 class="text-xl font-semibold text-bw-navy">{dict.financingPage.ctaTitle}</h2>
    <p class="mt-2 text-bw-gray">{dict.financingPage.ctaText}</p>
    <a
      href={`${homePath}#contact`}
      class="mt-4 inline-flex items-center rounded-md bg-bw-primary px-5 py-2.5 text-white text-sm font-semibold shadow hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bw-primary/60"
    >
      {dict.financingPage.ctaPrimary}
    </a>
  </section>
</BaseLayout>
